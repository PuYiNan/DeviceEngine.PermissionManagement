<Window x:Class="DeviceEngine.PermissionManagement.Editors.IgnoredControlsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑忽略控件列表" Height="400" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <Button x:Name="btnAdd" Content="添加" Click="btnAdd_Click" Width="50" DockPanel.Dock="Right" />
            <TextBox x:Name="txtNewControl" Margin="0,0,4,0" />
        </DockPanel>

        <ListBox x:Name="lstIgnored" Grid.Row="1" SelectionMode="Extended"
                 KeyDown="lstIgnored_KeyDown" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4">
            <Button x:Name="btnRemove" Content="删除选中项" Click="btnRemove_Click" Width="80" Margin="0,0,4,0" />
            <Button x:Name="btnClear" Content="清空全部" Click="btnClear_Click" Width="80" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="btnOK" Content="确定" Click="btnOK_Click" Width="60" IsDefault="True" Margin="0,0,4,0" />
            <Button x:Name="btnCancel" Content="取消" Click="btnCancel_Click" Width="60" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
